---
import { Image, getImage } from 'astro:assets';
import heroPhoto from '../assets/join-us/hero.jpg';
import phone1 from '../assets/join-us/phone1.png';
import phone2 from '../assets/join-us/phone2.png';
import { contact, joinUsVideos, type Translations } from '../i18n';

interface Props {
  t: Translations;
}

const { t } = Astro.props;

// Hero photo renders as a CSS background so the navy overlay and centered
// title follow the same pattern as the other pages.
const heroBg = await getImage({ src: heroPhoto, width: 1920, format: 'webp' });

const slides = [
  { photo: phone1, alt: t.joinUsPage.slideshow.tiktokAlt },
  { photo: phone2, alt: t.joinUsPage.slideshow.instagramAlt },
];

// Platform names and handles are brand identifiers, not translated copy.
const channels = [
  {
    name: 'WhatsApp',
    handle: contact.phoneDisplay,
    url: contact.whatsappUrl,
    text: t.joinUsPage.channels.whatsapp,
    icon: 'M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z',
  },
  {
    name: 'Instagram',
    handle: contact.instagram.label,
    url: contact.instagram.url,
    text: t.joinUsPage.channels.instagram,
    icon: 'M12 2.2c3.2 0 3.6 0 4.9.1 1.2.1 1.8.2 2.2.4.6.2 1 .5 1.4.9.4.4.7.8.9 1.4.2.4.4 1 .4 2.2.1 1.3.1 1.7.1 4.9s0 3.6-.1 4.9c-.1 1.2-.2 1.8-.4 2.2-.2.6-.5 1-.9 1.4-.4.4-.8.7-1.4.9-.4.2-1 .4-2.2.4-1.3.1-1.7.1-4.9.1s-3.6 0-4.9-.1c-1.2-.1-1.8-.2-2.2-.4-.6-.2-1-.5-1.4-.9-.4-.4-.7-.8-.9-1.4-.2-.4-.4-1-.4-2.2-.1-1.3-.1-1.7-.1-4.9s0-3.6.1-4.9c.1-1.2.2-1.8.4-2.2.2-.6.5-1 .9-1.4.4-.4.8-.7 1.4-.9.4-.2 1-.4 2.2-.4 1.3-.1 1.7-.1 4.9-.1M12 0C8.7 0 8.3 0 7 .1 5.8.1 4.9.3 4.1.6c-.8.3-1.5.7-2.2 1.4C1.3 2.6.9 3.3.6 4.1.3 4.9.1 5.8.1 7 0 8.3 0 8.7 0 12s0 3.7.1 5c0 1.2.2 2.1.5 2.9.3.8.7 1.5 1.4 2.1.6.7 1.3 1.1 2.1 1.4.8.3 1.7.5 2.9.5 1.3.1 1.7.1 5 .1s3.7 0 5-.1c1.2 0 2.1-.2 2.9-.5.8-.3 1.5-.7 2.1-1.4.7-.6 1.1-1.3 1.4-2.1.3-.8.5-1.7.5-2.9.1-1.3.1-1.7.1-5s0-3.7-.1-5c0-1.2-.2-2.1-.5-2.9-.3-.8-.7-1.5-1.4-2.1C21.4 1.3 20.7.9 19.9.6c-.8-.3-1.7-.5-2.9-.5C15.7 0 15.3 0 12 0Zm0 5.8a6.2 6.2 0 1 0 0 12.4 6.2 6.2 0 0 0 0-12.4ZM12 16a4 4 0 1 1 0-8 4 4 0 0 1 0 8Zm7.8-10.4a1.4 1.4 0 1 1-2.9 0 1.4 1.4 0 0 1 2.9 0Z',
  },
  {
    name: 'TikTok',
    handle: contact.tiktok.label,
    url: contact.tiktok.url,
    text: t.joinUsPage.channels.tiktok,
    icon: 'M19.6 6.7a5.6 5.6 0 0 1-3.4-3.9c-.1-.4-.1-.8-.1-1.3h-3.5v13.9a2.9 2.9 0 0 1-2.9 2.8 2.9 2.9 0 0 1 0-5.8c.3 0 .6 0 .9.1V9a6.4 6.4 0 1 0 5.5 6.3V8.6a9 9 0 0 0 5.2 1.6V6.8c-.6 0-1.2-.1-1.7-.1Z',
  },
];
---

<section
  class="page-hero"
  role="img"
  aria-label={t.joinUsPage.heroImageAlt}
  style={`background-image: url('${heroBg.src}')`}
>
  <h1>{t.joinUsPage.heroTitle}</h1>
</section>

<section class="connect">
  <h2 class="display-heading">{t.joinUsPage.connect.heading}</h2>
  <p class="body-large">{t.joinUsPage.connect.text}</p>
  <div class="connect-grid">
    <div class="slideshow">
      {slides.map((slide, index) => (
        <Image
          src={slide.photo}
          alt={slide.alt}
          width={720}
          class:list={[{ active: index === 0 }]}
        />
      ))}
    </div>
    <div class="channel-list">
      {channels.map((channel) => (
        <a class="channel-card" href={channel.url}>
          <svg
            viewBox="0 0 24 24"
            width="32"
            height="32"
            fill="currentColor"
            aria-hidden="true"
          >
            <path d={channel.icon}></path>
          </svg>
          <div class="channel-copy">
            <h3 class="section-heading">
              {channel.name}
              <span class="nav-label handle">{channel.handle}</span>
            </h3>
            <p class="body-regular">{channel.text}</p>
          </div>
        </a>
      ))}
    </div>
  </div>
  <a class="pill-cta eyebrow-label" href={contact.mapsUrl}>{t.footer.findUs}</a>
</section>

<section class="watch">
  <h2 class="display-heading">{t.joinUsPage.watch.heading}</h2>
  <div class="video-grid">
    {joinUsVideos.map((video) => (
      <iframe
        src={`https://www.youtube-nocookie.com/embed/${video.id}`}
        title={video.title}
        loading="lazy"
        allow="accelerometer; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
        referrerpolicy="strict-origin-when-cross-origin"
        allowfullscreen></iframe>
    ))}
  </div>
</section>

<script>
  const slideshow = document.querySelector('.slideshow');
  const slides = slideshow?.querySelectorAll('img') ?? [];
  if (
    slides.length > 1 &&
    !window.matchMedia('(prefers-reduced-motion: reduce)').matches
  ) {
    let current = 0;
    setInterval(() => {
      current = (current + 1) % slides.length;
      slides.forEach((slide, index) =>
        slide.classList.toggle('active', index === current),
      );
    }, 4000);
  }
</script>

<style>
  .page-hero {
    position: relative;
    /* Shorter band than the landing pages' full-screen heroes: this is a
       utility page, so the channels stay within reach. */
    min-height: 30vh;
    min-height: 30svh;
    background-color: var(--brand-navy);
    background-size: cover;
    background-position: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: var(--space-lg);
    padding: var(--space-3xl) var(--space-lg);
  }

  /* Parallax only where it renders reliably: wide pointer-driven screens.
     Touch browsers (iOS Safari especially) mishandle background-attachment: fixed. */
  @media (min-width: 901px) and (hover: hover) {
    .page-hero {
      background-attachment: fixed;
    }
  }

  .page-hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background: color-mix(in srgb, var(--brand-navy) 65%, transparent);
  }

  .page-hero h1 {
    position: relative;
    color: var(--heading);
    font-size: 34px;
    font-weight: 700;
    line-height: 1.1;
    text-transform: uppercase;
    letter-spacing: 2px;
    text-align: center;
  }

  .connect {
    max-width: var(--content-width);
    margin: 0 auto;
    padding: var(--space-4xl) var(--space-lg);
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-2xl);
  }

  .connect > .body-large {
    max-width: 720px;
  }

  .connect-grid {
    display: grid;
    grid-template-columns: 2fr 3fr;
    gap: var(--space-3xl);
    align-items: center;
    width: 100%;
    text-align: left;
  }

  /* Slides stack in the same grid cell and crossfade via the .active class. */
  .slideshow {
    display: grid;
    width: 100%;
    max-width: 420px;
    justify-self: center;
  }

  .slideshow img {
    grid-area: 1 / 1;
    width: 100%;
    height: auto;
    border-radius: var(--radius-md);
    opacity: 0;
    transition: opacity 0.8s ease;
  }

  .slideshow img.active {
    opacity: 1;
  }

  .channel-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
  }

  .channel-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    padding: var(--space-xl) var(--space-2xl);
    display: flex;
    align-items: center;
    gap: var(--space-lg);
    color: var(--text);
  }

  .channel-card svg {
    flex-shrink: 0;
  }

  .channel-copy {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .channel-copy .section-heading {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: var(--space-base);
  }

  .channel-card:hover {
    text-decoration: none;
    border-color: var(--accent);
  }

  .channel-card svg {
    color: var(--heading);
  }

  .channel-card:hover svg {
    color: var(--accent);
  }

  .handle {
    color: var(--accent);
  }

  .pill-cta {
    padding: var(--space-md) var(--space-2xl);
    border: 1px solid var(--heading);
    border-radius: var(--radius-pill);
    color: var(--heading);
  }

  .pill-cta:hover {
    background: var(--heading);
    color: var(--brand-navy);
    text-decoration: none;
  }

  .watch {
    max-width: var(--content-width);
    margin: 0 auto;
    padding: 0 var(--space-lg) var(--space-4xl);
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-2xl);
  }

  .video-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-lg);
    width: 100%;
  }

  .video-grid iframe {
    width: 100%;
    aspect-ratio: 16 / 9;
    border: 0;
    border-radius: var(--radius-md);
  }

  @media (max-width: 900px) {
    .page-hero h1 {
      font-size: 28px;
    }

    .connect {
      padding-top: var(--space-3xl);
      padding-bottom: var(--space-3xl);
    }

    .connect-grid {
      grid-template-columns: 1fr;
      gap: var(--space-2xl);
    }

    .channel-card {
      padding: var(--space-lg) var(--space-xl);
    }

    .watch {
      padding-bottom: var(--space-3xl);
    }

    .video-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
