---
import { getImage } from 'astro:assets';
import heroPosterFrame from '../assets/hero-poster.jpg';
import realCommunityPhoto from '../assets/real-community.jpg';
import sundayServicePhoto from '../assets/sunday-service.jpg';
import { giving, localePath, type Translations } from '../i18n';

interface Props {
  t: Translations;
}

const { t } = Astro.props;
const base = (path: string) => localePath(t.locale, path);

// Banner photos render as CSS backgrounds so background-attachment: fixed works.
const [sundayServiceBg, realCommunityBg] = await Promise.all([
  getImage({ src: sundayServicePhoto, width: 1920, format: 'webp' }),
  getImage({ src: realCommunityPhoto, width: 1920, format: 'webp' }),
]);

// The poster is frame 0 of the hero video, so playback takes over invisibly.
const heroPoster = await getImage({ src: heroPosterFrame, width: 1280, format: 'webp' });

// Every image dropped into src/assets/gallery/ joins the marquee automatically.
const galleryModules = import.meta.glob<{ default: ImageMetadata }>(
  '../assets/gallery/*.{jpg,jpeg,png,webp}',
  { eager: true },
);
const galleryPhotos = await Promise.all(
  Object.keys(galleryModules)
    .sort()
    .map((path) => getImage({ src: galleryModules[path].default, width: 900, format: 'webp' })),
);
// The track holds three copies of the set and shifts by exactly one copy per
// loop; the animation duration scales with the photo count so the drift speed
// stays constant as more photos are added.
const galleryDuration = `${galleryPhotos.length * 10}s`;
---

<section class="hero">
  <video
    id="hero-video"
    autoplay
    muted
    loop
    playsinline
    poster={heroPoster.src}
    preload="auto"
    aria-hidden="true"
    disablepictureinpicture
    disableRemotePlayback
  >
    <source src="/videos/hero.webm" type="video/webm" />
    <source src="/videos/hero.mp4" type="video/mp4" />
  </video>
  <script is:inline>
    (() => {
      const video = document.getElementById('hero-video');
      const reduced = matchMedia('(prefers-reduced-motion: reduce)');
      if (reduced.matches) video.removeAttribute('autoplay');
      new IntersectionObserver(([entry]) => {
        if (reduced.matches || !entry.isIntersecting) video.pause();
        else video.play().catch(() => {});
      }).observe(video);
    })();
  </script>
  <h1>{t.hero.title}</h1>
  <p class="large-subheading">{t.hero.tagline}</p>
</section>

<section class="welcome">
  <p class="large-subheading">{t.hero.subtitle}</p>
  <blockquote>
    <p class="body-large">{t.hero.verse}</p>
    <cite class="eyebrow-label">{t.hero.verseRef}</cite>
  </blockquote>
</section>

<section class="vision">
  <div class="vision-inner">
    <h2 class="display-heading">{t.vision.heading}</h2>
    <p class="large-subheading">{t.vision.text}</p>
  </div>
</section>

<section class="mission">
  <h2 class="display-heading">{t.mission.heading}</h2>
  <div class="pillars">
    {t.mission.pillars.map((pillar) => (
      <div class="pillar">
        <h3 class="section-heading">{pillar.tag}</h3>
        <p class="body-regular">{pillar.text}</p>
      </div>
    ))}
  </div>
</section>

<section class="banner" style={`background-image: url('${sundayServiceBg.src}')`}>
  <div class="banner-content">
    <h2 class="card-heading">{t.cards.sundayService.heading}</h2>
    <p class="large-subheading">{t.cards.sundayService.text}</p>
    <a class="banner-cta eyebrow-label" href={base('/sunday-service')}>{t.cards.sundayService.heading}</a>
  </div>
</section>

<section class="about">
  <p class="large-subheading">{t.about.intro}</p>
  <p class="body-large">{t.about.text}</p>
</section>

<section class="banner" style={`background-image: url('${realCommunityBg.src}')`}>
  <div class="banner-content">
    <h2 class="card-heading">{t.cards.realCommunity.heading}</h2>
    <p class="large-subheading">{t.cards.realCommunity.text}</p>
    <a class="banner-cta eyebrow-label" href={base('/real-community')}>{t.cards.realCommunity.heading}</a>
  </div>
</section>

<section class="giving">
  <div class="giving-inner">
    <h2 class="display-heading">{t.giving.heading}</h2>
    <p class="body-large">{t.giving.text}</p>
    <p class="giving-account">
      {giving.account}<br />{giving.accountNumber}
    </p>
    <p class="giving-note">{t.giving.note}</p>
  </div>
</section>

<section class="gallery" aria-hidden="true">
  <div class="gallery-track" style={`animation-duration: ${galleryDuration}`}>
    {[...galleryPhotos, ...galleryPhotos, ...galleryPhotos].map((photo) => (
      <img src={photo.src} alt="" width={photo.attributes.width} height={photo.attributes.height} loading="lazy" decoding="async" />
    ))}
  </div>
</section>

<style>
  section {
    max-width: var(--content-width);
    margin: 0 auto;
    padding: var(--space-3xl) var(--space-lg);
  }

  .hero {
    position: relative;
    max-width: none;
    /* Navy stays as the base layer so text sits on brand color until the
       poster/video paints. */
    background: var(--brand-navy);
    color: var(--heading);
    text-align: center;
    padding: var(--space-3xl) var(--space-lg);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: var(--space-lg);
    /* Full-screen hero: viewport minus the utility bar (~30px) and sticky nav (~74px). */
    min-height: calc(100vh - 104px);
    min-height: calc(100svh - 104px);
  }

  .hero video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* 55% keeps the white headline readable over the loop's brightest shots
     (the opening balloons); the mostly-dark footage still reads clearly.
     ::after paints above the video without needing z-index. */
  .hero::after {
    content: '';
    position: absolute;
    inset: 0;
    background: color-mix(in srgb, var(--brand-navy) 55%, transparent);
  }

  .hero h1,
  .hero .large-subheading {
    position: relative;
    z-index: 1;
  }

  .hero h1 {
    font-size: 34px;
    font-weight: 700;
    line-height: 1.1;
    text-transform: uppercase;
    letter-spacing: 2px;
  }

  .welcome {
    text-align: center;
    padding-top: var(--space-4xl);
    padding-bottom: var(--space-4xl);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-2xl);
  }

  .welcome .large-subheading {
    max-width: 720px;
  }

  .welcome blockquote {
    max-width: 680px;
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .welcome cite {
    font-style: normal;
    color: var(--text-muted);
  }

  .mission {
    display: flex;
    flex-direction: column;
    gap: var(--space-2xl);
    padding-top: var(--space-4xl);
    padding-bottom: var(--space-4xl);
    text-align: center;
  }

  .pillars {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-3xl);
  }

  .pillar {
    display: flex;
    flex-direction: column;
    gap: var(--space-base);
  }

  .pillar .body-regular {
    line-height: 20px;
  }

  .vision {
    max-width: none;
    background: var(--surface);
    padding: var(--space-3xl) var(--space-lg);
  }

  .vision-inner {
    max-width: var(--content-width);
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-lg);
    text-align: center;
  }

  .vision .large-subheading {
    max-width: 880px;
  }

  .banner {
    position: relative;
    max-width: none;
    height: 520px;
    background-size: cover;
    background-position: center;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: var(--space-3xl) var(--space-lg);
  }

  .banner::before {
    content: '';
    position: absolute;
    inset: 0;
    background: color-mix(in srgb, var(--brand-navy) 75%, transparent);
  }

  .banner-content .large-subheading {
    white-space: pre-line;
  }

  .banner-content {
    position: relative;
    max-width: 760px;
    color: var(--heading);
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-lg);
  }

  .banner-cta {
    margin-top: var(--space-base);
    padding: var(--space-md) var(--space-2xl);
    border: 1px solid var(--heading);
    border-radius: var(--radius-pill);
    color: var(--heading);
  }

  .banner-cta:hover {
    background: var(--heading);
    color: var(--brand-navy);
    text-decoration: none;
  }

  .gallery {
    max-width: none;
    padding: var(--space-4xl) 0;
    overflow: hidden;
  }

  .gallery-track {
    display: flex;
    width: max-content;
    animation: gallery-drift linear infinite;
  }

  /* Spacing lives on the tiles (not flex gap) so one copy of the photo set is
     exactly a third of the track and the -100%/3 shift loops seamlessly. */
  .gallery-track img {
    height: 300px;
    width: auto;
    margin-right: var(--space-base);
    flex-shrink: 0;
  }

  @keyframes gallery-drift {
    to {
      transform: translateX(calc(-100% / 3));
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .gallery {
      overflow-x: auto;
    }

    .gallery-track {
      animation: none;
    }
  }

  .about {
    max-width: var(--content-width);
    margin: 0 auto;
    padding: var(--space-4xl) var(--space-lg);
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-2xl);
  }

  .about .large-subheading {
    max-width: 880px;
  }

  .about .body-large {
    max-width: 720px;
  }

  .giving {
    max-width: none;
    background: var(--surface);
    padding: var(--space-4xl) var(--space-lg);
  }

  .giving-inner {
    max-width: 720px;
    margin: 0 auto;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-2xl);
  }

  .giving-account {
    font-size: 20px;
    font-weight: 700;
    line-height: 28px;
    color: var(--heading);
  }

  .giving-note {
    font-size: 14px;
    font-weight: 400;
    line-height: 18px;
    letter-spacing: 0.18px;
    color: var(--text);
  }

  /* Parallax only where it renders reliably: wide pointer-driven screens.
     Touch browsers (iOS Safari especially) mishandle background-attachment: fixed. */
  @media (min-width: 901px) and (hover: hover) {
    .banner {
      background-attachment: fixed;
    }
  }

  @media (max-width: 900px) {
    .hero h1 {
      font-size: 28px;
    }

    .welcome,
    .mission {
      padding-top: var(--space-3xl);
      padding-bottom: var(--space-3xl);
    }

    .pillars {
      grid-template-columns: 1fr;
    }

    .banner {
      height: auto;
      min-height: 420px;
    }

    .gallery {
      padding-top: var(--space-3xl);
      padding-bottom: var(--space-3xl);
    }

    .gallery-track img {
      height: 200px;
    }

    .about,
    .giving {
      padding-top: var(--space-3xl);
      padding-bottom: var(--space-3xl);
    }

    .hero .large-subheading,
    .welcome .large-subheading,
    .vision .large-subheading,
    .banner .large-subheading,
    .about .large-subheading {
      font-size: 22px;
      line-height: 30px;
    }
  }
</style>
